<?xml version="1.0" encoding="UTF-8"?>
<!--
  Konfiguracja Tika dla kroku 1 (ekstrakcja + OCR).

  - DefaultParser zachowuje wszystkie domyslne parsery Tiki (DOCX, XLSX, e-mail...).
  - TesseractOCRParser: domyslny jezyk OCR = pol+eng (lapie tez wtracenia/nazwy ang.).
  - PDFParser ocrStrategy=auto: tekstowe PDF-y czytane natywnie (PDFBox),
    a strony bedace skanem (obraz) sa dodatkowo OCR-owane.
-->
<properties>
  <parsers>
    <parser class="org.apache.tika.parser.DefaultParser"/>

    <parser class="org.apache.tika.parser.ocr.TesseractOCRParser">
      <params>
        <param name="language" type="string">pol+eng</param>
      </params>
    </parser>

    <parser class="org.apache.tika.parser.pdf.PDFParser">
      <params>
        <param name="ocrStrategy" type="string">auto</param>
      </params>
    </parser>
  </parsers>
</properties>
