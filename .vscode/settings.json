{
  // Interpreter z lokalnego venv (legacy ms-python.python).
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Nowe rozszerzenie ms-python.vscode-python-envs zarzadza srodowiskami per-projekt.
  // Deklaracja projektu tutaj sprawia, ze venv jest powiazany na stale (bez recznego
  // "Set As Project Environment" przy kazdym uruchomieniu VS Code).
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ],
  // Auto-aktywacja wybranego interpretera (.venv) w nowych terminalach. To ustawienie
  // legacy ms-python.python JEST workspace-scoped, wiec dziala z pliku projektu.
  // (Uwaga: 'python-envs.terminal.autoActivationType' nowego rozszerzenia jest
  //  machine/remote-scoped — w .vscode/settings.json bylo IGNOROWANE; przeniesione do
  //  ustawien Remote/User, patrz nizej.)
  "python.terminal.activateEnvironment": true,

  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,

  // Pakiet `app` zyje w api/ (izolowany build context uslugi FastAPI). Pylance nie
  // czyta pytest `pythonpath` z pyproject.toml, wiec dla analizy statycznej (import
  // app.*) wskazujemy katalog osobno. Odpowiednik `pythonpath = ["api"]`.
  "python.analysis.extraPaths": ["api"]
}
