# Skopiuj do .env i dostosuj.  Zasada projektu: cala konfiguracja przez ENV.
# .env NIE trafia do repozytorium (patrz .gitignore).
#
# Uwaga: TIKA_PORT i FASTAPI_PORT to zmienne dla docker-compose (mapowanie portow
# na hoscie) — aplikacja FastAPI ich NIE czyta. Reszta to ustawienia aplikacji
# (Settings w api/app/config.py); zakomentowane = uzywany jest default z kodu.

# --- Krok 1: Tika ---
# Port, na ktorym tika-server jest wystawiony na hoscie.
TIKA_PORT=9998

# --- Krok 2: FastAPI ---
# Port, na ktorym API jest wystawione na hoscie.
FASTAPI_PORT=8000
# Adres Tiki widziany przez FastAPI. W docker-compose ustawiany na http://tika:9998;
# dla testow/dev na hoscie domyslnie http://localhost:9998.
# TIKA_URL=http://localhost:9998

# --- Krok 2: dostawca LLM (klient dochodzi w kroku 2.2) ---
# Faza 1 = komercyjne API (rekomendacja: Azure OpenAI, region UE).
# Na dev/test domyslnie 'fake' — pipeline bez prawdziwego API, nic nie wychodzi na zewnatrz.
LLM_PROVIDER=fake
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# LLM_API_VERSION=        # tylko Azure OpenAI

# --- Krok 2: opcjonalny tuning (domyslne wartosci w api/app/config.py) ---
# Zwykle nie trzeba ruszac; podane wartosci to biezace defaulty (dla orientacji).
# TIKA_TIMEOUT_SECONDS=120          # timeout ekstrakcji w Tice (OCR bywa wolny)
# HEALTH_CHECK_TIMEOUT_SECONDS=3    # krotki ping Tiki w /health
# LLM_TIMEOUT_SECONDS=60            # timeout wolania LLM (klient dochodzi w 2.2)
