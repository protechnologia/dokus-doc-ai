# Skopiuj do .env i dostosuj.  Zasada projektu: cala konfiguracja przez ENV.
# .env NIE trafia do repozytorium (patrz .gitignore).
#
# Uwaga: TIKA_PORT i FASTAPI_PORT to zmienne dla docker-compose (mapowanie portow
# na hoscie) — aplikacja FastAPI ich NIE czyta. Reszta to ustawienia aplikacji
# (Settings w api/app/config.py); zakomentowane = uzywany jest default z kodu.

# --- Tika ---
# Port, na ktorym tika-server jest wystawiony na hoscie.
TIKA_PORT=9998

# --- FastAPI ---
# Port, na ktorym API jest wystawione na hoscie.
FASTAPI_PORT=8000
# Adres nasluchu API na hoscie. Domyslnie 0.0.0.0 (wszystkie interfejsy) — wygodne na dev.
# Na produkcji zawezic: do adresu interfejsu LAN, przez ktory laczy sie DOKUS, albo do
# 127.0.0.1, gdy DOKUS stoi na tej samej maszynie. Czyta to docker-compose (nie aplikacja).
# BIND_ADDR=127.0.0.1
# Adres Tiki widziany przez FastAPI. W docker-compose ustawiany na http://tika:9998;
# dla testow/dev na hoscie domyslnie http://localhost:9998.
# TIKA_URL=http://localhost:9998

# --- Ollama (tylko warstwa docker-compose.bielik.yml) ---
# Port kontenera Ollamy wystawiony na hoscie — WYLACZNIE pod debug/pull z hosta
# (np. `curl localhost:11434/api/tags`). FastAPI go nie uzywa: gada po sieci compose.
# OLLAMA_PORT=11434

# --- Dostawca LLM ---
# Obslugiwane: 'fake' (dev/test, offline), 'openai' (komercyjne API),
# 'ollama' (lokalny Bielik przez Ollama; endpoint zgodny z API OpenAI).
# Na dev/test domyslnie 'fake' — pipeline bez prawdziwego API, nic nie wychodzi na zewnatrz.
LLM_PROVIDER=fake
# Dla 'openai' wymagane: klucz + model. Przyklad:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-proj-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=           # opcjonalnie: wlasny gateway zgodny z API OpenAI (.../v1)
#
# Dla 'ollama' wymagane: model + base_url (klucz zbedny — Ollama go ignoruje). Przyklad:
# LLM_PROVIDER=ollama
# LLM_MODEL=SpeakLeash/bielik-11b-v3.0-instruct:Q4_K_M
# LLM_BASE_URL=http://ollama:11434/v1

# --- Summaryzacja (POST /summarize) ---
# Gorny limit ZNAKOW tekstu wysylanego do LLM (straznik okna kontekstu modelu). Powyzej:
# pierwsze N znakow + log + metadana "truncated". Domyslnie 90 000 — spojnie z MAX_OCR_PAGES=30
# (~3000 znakow/strone). Pod mniejszy model (Bielik, ~32k tok.) obnizyc (patrz README ->
# "Spojnosc limitow pipeline'u").
# LLM_MAX_INPUT_CHARS=90000

# --- Ekstrakcja (POST /extract) ---
# Gorny limit rozmiaru ZDEKODOWANEGO pliku (bajty). Powyzej -> HTTP 413. Domyslnie 20 MiB.
# MAX_UPLOAD_BYTES=20971520
# Limit liczby stron PDF wysylanych do Tiki (straznik OCR). PDF powyzej N stron
# jest ciety do pierwszych N PRZED ekstrakcja (log + metadane "przetworzono N z M stron").
# Dotyczy kazdego duzego PDF (de facto MAX_PDF_PAGES), nie tylko skanow. Domyslnie 30.
# MAX_OCR_PAGES=30

# --- Opcjonalny tuning (domyslne wartosci w api/app/config.py) ---
# Zwykle nie trzeba ruszac; podane wartosci to biezace defaulty (dla orientacji).
# TIKA_TIMEOUT_SECONDS=120          # timeout ekstrakcji w Tice (OCR bywa wolny)
# HEALTH_CHECK_TIMEOUT_SECONDS=3    # krotki ping Tiki w /health
# LLM_TIMEOUT_SECONDS=60            # timeout wolania LLM
